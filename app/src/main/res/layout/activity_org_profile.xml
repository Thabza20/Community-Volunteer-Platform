<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_purple"
        app:title="Edit Profile"
        app:titleTextColor="@color/white"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- HEADER removed since it's in toolbar -->

        <!-- PROFILE CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- LOGO -->
                <ImageView
                    android:id="@+id/imgOrgLogo"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_launcher_foreground"
                    android:scaleType="centerCrop"
                    android:background="@android:color/darker_gray"
                    android:padding="6dp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnChangeLogo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change Logo"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp" />

                <!-- ORG NAME -->
                <EditText
                    android:id="@+id/etOrgName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Organization Name"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp" />

                <!-- EMAIL -->
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email"
                    android:enabled="false"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp" />

                <!-- ORG NUMBER -->
                <EditText
                    android:id="@+id/etOrgNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Organization Number"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp" />

                <!-- LOCATION -->
                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Location"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp" />

                <!-- DETAILS -->
                <EditText
                    android:id="@+id/etOrgDetails"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="Organization Details"
                    android:gravity="top"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp" />

                <!-- PRIMARY PHONE -->
                <EditText
                    android:id="@+id/etPrimaryPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Primary Phone Number"
                    android:inputType="phone"
                    android:padding="14dp"
                    android:layout_marginBottom="20dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ACTION BUTTONS -->

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Save Changes"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Change Password"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnDeleteAccount"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Delete Account"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F44336" />

    </LinearLayout>

</ScrollView>
</LinearLayout>
