<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CommunityVolunteerPlatform">

        <activity
            android:name=".activities.SignUpActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.MainActivity"
            android:exported="false" />
        <activity
            android:name=".activities.VolunteerDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".activities.OrganizationDashboardActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.ManageOpportunitiesActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.BrowseOpportunitiesActivity"
            android:exported="false"
            android:label="Browse Opportunities"
            android:parentActivityName=".activities.VolunteerDashboardActivity" />
        <activity
            android:name=".activities.OpportunityDetailsActivity"
            android:exported="false"
            android:label="Opportunity Details"
            android:parentActivityName=".activities.BrowseOpportunitiesActivity" />

        <meta-data
            android:name="com.google.android.gms.recaptcha.RECAPTCHA_SITE_KEY"
            android:value="6LcYHpkqAAAAAAnPixG3F-0BZqR6gTHPZyD6zS_z" />

        <meta-data
            android:name="CLOUDINARY_URL"
            android:value="cloudinary://${CLOUDINARY_API_KEY}:${CLOUDINARY_API_SECRET}@${CLOUDINARY_CLOUD_NAME}" />

        <activity
            android:name=".activities.PassportActivity"
            android:label="My Passport"
            android:parentActivityName=".activities.VolunteerDashboardActivity" />

        <activity
            android:name=".activities.EditProfileActivity"
            android:label="Edit Profile"
            android:parentActivityName=".activities.PassportActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.AiRecommendationsActivity"
            android:label="For You"
            android:parentActivityName=".activities.VolunteerDashboardActivity" />

    </application>

</manifest>